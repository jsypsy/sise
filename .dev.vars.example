# Cloudflare 로컬 미리보기(pnpm cf:preview)용 변수.
# 이 파일을 .dev.vars로 복사해 실제 값을 채우세요(.dev.vars는 gitignore됨).

# --- 빌드 변수 (NEXT_PUBLIC_*, 빌드 시 인라인) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_R2_PUBLIC_URL=
NEXT_PUBLIC_SITE_URL=
# NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-...   # 애드센스 승인 후

# --- 런타임 시크릿 ---
REVALIDATE_SECRET=
# 선택(피드백 폼 이메일/웹훅 — 없으면 저장만):
# RESEND_API_KEY=
# FEEDBACK_EMAIL_TO=
# FEEDBACK_EMAIL_FROM=
# FEEDBACK_WEBHOOK_URL=

# 워커에 넣지 말 것(스크립트/Actions 전용): SUPABASE_SERVICE_ROLE_KEY, MOLIT_SERVICE_KEY, R2 액세스 키
